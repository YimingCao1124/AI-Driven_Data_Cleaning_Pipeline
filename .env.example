# =========================================================================
# AI Data Extraction Studio — Example Environment File
# Copy this file to `.env` (at the project root) before starting the app.
# All values shown below are the safe defaults used in V1 demo mode.
# =========================================================================

# ---- LLM provider ----
# V1 supports only `mock`. Real providers are planned for V3 — see README Roadmap.
MODEL_PROVIDER=mock
MODEL_NAME=mock-extractor

# ---- Extraction behavior ----
MAX_RETRIES=2
TEMPERATURE=0
MAX_CONCURRENCY=3

# ---- Database ----
# SQLite by default. The `data/` directory must exist (created automatically on startup).
DATABASE_URL=sqlite:///./data/app.db

# ---- File storage ----
UPLOAD_DIR=./storage/uploads
EXPORT_DIR=./storage/exports

# ---- CORS ----
# Comma-separated list of origins allowed to call the API.
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# Used by the Next.js app to locate the backend.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# =========================================================================
# Reserved for V3 (NOT used in V1 — leave blank):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# =========================================================================
