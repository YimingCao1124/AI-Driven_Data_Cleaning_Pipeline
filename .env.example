# AI Data Extraction Studio — example environment file.
# Copy this file to `.env` at the project root before starting the app.

# ---- LLM provider ----
# Pick one of:
#   anthropic   Real Claude model (recommended for production-quality extraction).
#               Requires ANTHROPIC_API_KEY below.
#   mock        Heuristic offline client. Use only for the zero-config demo or CI.
#
# Default below is `mock` so a fresh clone runs end-to-end with no keys. Switch
# to `anthropic` once you have a key.
MODEL_PROVIDER=mock
MODEL_NAME=mock-extractor

# Anthropic-specific settings (used only when MODEL_PROVIDER=anthropic).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model id — `claude-sonnet-4-6` is the balanced default; `claude-haiku-4-5`
# is cheaper/faster; `claude-opus-4-7` is the highest quality.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Extraction behavior ----
MAX_RETRIES=2
TEMPERATURE=0
MAX_CONCURRENCY=3

# ---- Database — SQLite by default; the data/ directory is created automatically.
DATABASE_URL=sqlite:///./data/app.db

# ---- File storage ----
UPLOAD_DIR=./storage/uploads
EXPORT_DIR=./storage/exports

# ---- CORS — comma-separated list of origins allowed to call the API.
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Frontend — points the Next.js app at the backend.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ---- Reserved for additional providers (V3 roadmap):
# OPENAI_API_KEY=
